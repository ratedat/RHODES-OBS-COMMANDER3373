{
  "name": "rhodes-obs-commander3373",
  "version": "0.1.0",
  "description": "Suki/Avalonia sidecar and OBS overlay API for Arknights Integrated Strategies.",
  "author": "ratedat",
  "private": true,
  "type": "module",
  "main": "app/server.mjs",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "dev": "node app/server.mjs",
    "dev:5174": "node app/server.mjs --port 5174",
    "suki:build": "dotnet build apps/rhodes-suki/RhodesSuki.csproj",
    "suki:test": "dotnet run --project tests/rhodes-suki/RhodesSuki.ServiceTests.csproj",
    "suki:run": "dotnet run --project apps/rhodes-suki/RhodesSuki.csproj",
    "apple:build": "dotnet build apps/rhodes-apple-design/RhodesAppleDesign.csproj",
    "apple:publish": "node tools/publish-apple-design-prototype.mjs",
    "maa:resource:generate": "node tools/generate-maa-resource.mjs",
    "maa:resource:check": "node tools/generate-maa-resource.mjs --check",
    "maa:interface:generate": "node tools/generate-maa-interface.mjs",
    "maa:interface:check": "node tools/generate-maa-interface.mjs --check",
    "maa:contract:check": "node tools/check-maa-contract.mjs",
    "maa:check": "npm run maa:resource:check && npm run maa:interface:check && npm run maa:contract:check",
    "suki:check": "npm run maa:check && npm run suki:test",
    "suki:publish:portable": "node tools/publish-suki-portable.mjs",
    "suki:package:public-debug": "node tools/package-suki-public-debug.mjs",
    "data:update": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/update-data.ps1",
    "data:update:plan": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File tools/update-data.ps1 -PlanOnly",
    "data:diff": "node tools/compare-data-update.mjs --before data --after data --out review/update-runs/manual-compare",
    "verify:desktop": "npm run suki:check && npm run suki:build",
    "ocr:sync-maa": "node tools/sync-maa-ocr-assets.mjs",
    "ocr:sync-maa:models": "node tools/sync-maa-ocr-assets.mjs --models",
    "ocr:sync-maa-operator": "node tools/sync-maa-operator-ocr-map.mjs"
  },
  "devDependencies": {},
  "license": "AGPL-3.0-only"
}
