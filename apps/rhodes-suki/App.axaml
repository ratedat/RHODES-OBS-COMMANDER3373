<Application
    x:Class="RhodesSuki.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:suki="clr-namespace:SukiUI;assembly=SukiUI"
    RequestedThemeVariant="Dark">
  <Application.Styles>
    <suki:SukiTheme ThemeColor="Green" />
    <StyleInclude Source="avares://RhodesSuki/Views/WorkbenchTheme.axaml" />
  </Application.Styles>
</Application>
