<Window
    x:Class="RhodesSuki.Views.HudWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    WindowDecorations="None"
    TransparencyLevelHint="Transparent"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ShowActivated="False"
    CanResize="False"
    SizeToContent="WidthAndHeight"
    Title="RHODES HUD">
  <!--
    本人用HUD小窓。MAA本家のログ小窓と同じ「デスクトップ最前面の枠なしウィンドウを
    エミュレータの上に重ねる」方式。エミュレータの中には描画しないため、
    ADBスクリーンショット(=認識対象画像)には一切写り込まない。
  -->
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
  </Window.Styles>
  <Border CornerRadius="10" Background="#E6101617" BorderBrush="#3A4A4C" BorderThickness="1" Padding="10" MinWidth="280" MaxWidth="440">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
      <!-- グリップ行: ドラッグ移動 / クリック透過 / 閉じる -->
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" Background="Transparent" PointerPressed="GripPointerPressed">
        <TextBlock Text="RHODES" FontSize="11" FontWeight="Bold" Opacity="0.55" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding CampaignHeaderTitle}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
        <CheckBox Grid.Column="2" Content="クリック透過" FontSize="11" IsChecked="{Binding IsHudClickThrough, Mode=TwoWay}"
                  ToolTip.Tip="ONの間はHUDがマウスを素通しします。解除はメインウィンドウのHUDトグルをOFF→ONしてください。" />
        <Button Grid.Column="3" Content="✕" Padding="7,1" FontSize="11" Click="CloseClick" />
      </Grid>

      <!-- ラン状態チップ (出力ワークスペースのHUD設定でフィルタ済み) -->
      <ItemsControl ItemsSource="{Binding HudChips}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border CornerRadius="6" Padding="8,4" Margin="0,0,6,6" Background="#CC121A1B" BorderBrush="#2B3638" BorderThickness="1" MinWidth="72">
              <StackPanel Spacing="0">
                <TextBlock Text="{Binding Label}" FontSize="10" Opacity="0.6" />
                <TextBlock Text="{Binding Value}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="200" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- 所持秘宝: 現在ISの選択済み秘宝だけをHUD向けに圧縮表示 -->
      <Border Grid.Row="2" IsVisible="{Binding IsHudRelicsVisible}" CornerRadius="8" Padding="8" Background="#A6121A1B" BorderBrush="#2B3638" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock Text="秘宝" FontSize="10" FontWeight="Bold" Opacity="0.62" />
          <ScrollViewer MaxHeight="132" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding HudRelics}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border CornerRadius="6" Padding="5,3" Margin="0,0,6,6" Background="#CC101617" BorderBrush="#324042" BorderThickness="1" MaxWidth="190">
                    <Grid ColumnDefinitions="24,*" ColumnSpacing="6">
                      <Border Width="24" Height="24" CornerRadius="4" ClipToBounds="True" Background="#1F282A">
                        <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="Uniform" />
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Border>

      <!-- Tier / 直近反映 / 接続状態 -->
      <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10">
        <Border CornerRadius="10" Padding="8,2" IsVisible="{Binding IsHudConnectionVisible}"
                Background="{Binding ConnectionStatusBackground}" BorderBrush="{Binding ConnectionStatusBorder}" BorderThickness="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding ConnectionStatusLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#FFFFFF" />
        </Border>
        <TextBlock Text="{Binding ManualDifficultyTierLabel}" IsVisible="{Binding IsHudTierVisible}" FontSize="12" Foreground="#FFFFFF" VerticalAlignment="Center" />
        <TextBlock Text="{Binding LastCandidateApplySummary}" IsVisible="{Binding IsHudApplySummaryVisible}" FontSize="11" Opacity="0.55" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="240" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
