<suki:SukiWindow
    x:Class="RhodesSuki.Views.MainWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:workspaces="clr-namespace:RhodesSuki.Views.Workspaces"
    mc:Ignorable="d"
    Width="1540"
    Height="920"
    MinWidth="1280"
    MinHeight="760"
    Title="{Binding Title}">
  <!--
    シェル設計:
      Top    : タイトル / IS選択 / 接続ピル(クリックで接続画面へ) / 主アクション
      Left   : ワークスペースナビ (選択状態を常時表示)
      Center : 選択中ワークスペースが全幅を使う。常設右ペインは廃止。
      Bottom : ステータスバー (+ 処理中表示)
    プレビュー・候補は認識ワークスペース内、報告取込・Frame再認識はデバッグ内で完結する。
  -->
  <Grid RowDefinitions="74,*,30">
    <Border Classes="appleToolbar">
      <Grid ColumnDefinitions="300,240,*,Auto,Auto,Auto" ColumnSpacing="10">
        <StackPanel Spacing="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" />
          <TextBlock Text="BROADCAST CONTROL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WorkbenchThemeAccent}" />
        </StackPanel>

        <ComboBox Grid.Column="1"
                  Width="240"
                  VerticalAlignment="Center"
                  ItemsSource="{Binding Campaigns}"
                  SelectedItem="{Binding SelectedCampaign, Mode=TwoWay}"
                  ItemTemplate="{StaticResource CampaignComboItemTemplate}"
                  SelectionBoxItemTemplate="{StaticResource CampaignComboItemTemplate}"
                  ToolTip.Tip="統合戦略テーマを切り替えます。検証用ではIS#2～IS#6を選択できます。" />

        <Button Grid.Column="3"
                Command="{Binding SetWorkspaceCommand}"
                CommandParameter="runtime"
                Background="{Binding ConnectionStatusBackground}"
                BorderBrush="{Binding ConnectionStatusBorder}"
                BorderThickness="1"
                CornerRadius="17"
                Padding="12,6"
                VerticalAlignment="Center"
                ToolTip.Tip="クリックで接続画面を開きます">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding ConnectionStatusLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{Binding ConnectionStatusForeground}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ConnectionStatusDetail}" FontFamily="Consolas" FontSize="11" Opacity="0.72" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button Grid.Column="4"
                Classes="primaryAction"
                Content="取得して反映"
                Command="{Binding RunAllOperationalRecognitionAndApplyCommand}"
                ToolTip.Tip="現在テーマの共通値・固有値・オペレーター・秘宝を順に取得して反映します" />
        <Button Grid.Column="5" Classes="tertiaryAction" Content="⋯" Width="48" ToolTip.Tip="接続設定・HUD・報告">
          <Button.Flyout>
            <MenuFlyout>
              <MenuItem Header="ADB接続設定" Command="{Binding SetWorkspaceCommand}" CommandParameter="runtime" />
              <MenuItem Header="HUDを表示／非表示" Command="{Binding ToggleHudVisibilityCommand}" />
              <MenuItem Header="バグ報告ZIPを作成" Command="{Binding CreateBugReportBundleCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="190,*">
      <Border Classes="appleSidebar">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
          <TextBlock Text="ワークスペース" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource WorkbenchTextTertiary}" Margin="12,8,0,4" />
          <ListBox Grid.Row="1"
                 Classes="navList"
                 ItemsSource="{Binding WorkspaceNav}"
                 SelectedItem="{Binding SelectedWorkspaceNavItem, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WorkbenchTextTertiary}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
          </ListBox>
          <StackPanel Grid.Row="2" Spacing="6" Margin="8">
            <Button Classes="tertiaryAction" Content="ADB接続設定" HorizontalContentAlignment="Left"
                    Command="{Binding SetWorkspaceCommand}" CommandParameter="runtime" />
            <Button Classes="tertiaryAction" Content="報告ZIP" HorizontalContentAlignment="Left"
                    Command="{Binding CreateBugReportBundleCommand}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="1" ClipToBounds="True" MinWidth="0" Classes="appleWorkspace">
        <Grid>
          <workspaces:RunWorkspaceView IsVisible="{Binding IsRunWorkspaceVisible}" />
          <workspaces:SpecialWorkspaceView IsVisible="{Binding IsSpecialWorkspaceVisible}" />
          <workspaces:ChoicesWorkspaceView IsVisible="{Binding IsChoicesWorkspaceVisible}" />
          <workspaces:RecognitionWorkspaceView IsVisible="{Binding IsRecognitionWorkspaceVisible}" />
          <workspaces:OutputWorkspaceView IsVisible="{Binding IsOutputWorkspaceVisible}" />
          <workspaces:RuntimeWorkspaceView IsVisible="{Binding IsRuntimeWorkspaceVisible}" />
          <workspaces:DebugWorkspaceView IsVisible="{Binding IsDebugWorkspaceVisible}" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="statusBar">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsBusy}">
          <ProgressBar IsIndeterminate="True" Width="70" Height="4" VerticalAlignment="Center" />
          <TextBlock Text="処理中" FontSize="12" Opacity="0.75" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" Opacity="0.8" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding CaptureState}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="480" Opacity="0.55" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</suki:SukiWindow>
