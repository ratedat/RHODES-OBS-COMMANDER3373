<suki:SukiWindow
    x:Class="RhodesSuki.Views.MainWindow"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:workspaces="clr-namespace:RhodesSuki.Views.Workspaces"
    mc:Ignorable="d"
    Width="1500"
    Height="900"
    MinWidth="1180"
    MinHeight="720"
    Title="{Binding Title}">
  <!--
    シェル設計:
      Top    : タイトル / IS選択 / 接続ピル(クリックで接続画面へ) / 主アクション
      Left   : ワークスペースナビ (選択状態を常時表示)
      Center : 選択中ワークスペースが全幅を使う。常設右ペインは廃止。
      Bottom : ステータスバー (+ 処理中表示)
    プレビュー・候補は認識ワークスペース内、報告取込・Frame再認識はデバッグ内で完結する。
  -->
  <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="10">
    <Border Classes="panel" Padding="12,10">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="14">
        <StackPanel Spacing="0" VerticalAlignment="Center">
          <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="検証ワークベンチ" Classes="caption" />
        </StackPanel>

        <ComboBox Grid.Column="1"
                  Width="250"
                  VerticalAlignment="Center"
                  ItemsSource="{Binding Campaigns}"
                  SelectedItem="{Binding SelectedCampaign, Mode=TwoWay}"
                  ItemTemplate="{StaticResource CampaignComboItemTemplate}"
                  SelectionBoxItemTemplate="{StaticResource CampaignComboItemTemplate}"
                  ToolTip.Tip="統合戦略テーマを切り替えます。検証用ではIS#2～IS#6を選択できます。" />

        <Button Grid.Column="3"
                Command="{Binding SetWorkspaceCommand}"
                CommandParameter="runtime"
                Background="{Binding ConnectionStatusBackground}"
                BorderBrush="{Binding ConnectionStatusBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                VerticalAlignment="Center"
                ToolTip.Tip="クリックで接続画面を開きます">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding ConnectionStatusLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{Binding ConnectionStatusForeground}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ConnectionStatusDetail}" FontFamily="Consolas" FontSize="11" Opacity="0.72" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="接続・撮影" Command="{Binding ConnectAndCaptureCommand}"
                  IsVisible="{Binding IsGlobalConnectAndCaptureVisible}"
                  ToolTip.Tip="保存済みADB設定で接続し、スクリーンショットを1枚取得します" />
          <Button Classes="primary" Content="ADB取得・認識・反映" Command="{Binding RunSelectedProfileRecognitionAndApplyCommand}"
                  ToolTip.Tip="保存済みADB設定で接続し、撮影・認識・状態反映まで自動実行します" />
          <Button Content="報告ZIP" Command="{Binding CreateBugReportBundleCommand}" />
          <ToggleButton Content="HUD" IsChecked="{Binding IsHudVisible, Mode=TwoWay}"
                        ToolTip.Tip="本人用の透過メモ小窓をエミュレータの上に重ねます (MAAのログ小窓と同型)。クリック透過で詰まったらここをOFF→ONで復帰。" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="176,*" ColumnSpacing="10">
      <Border Classes="panel" Padding="8">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock Text="WORKSPACE" FontSize="10" FontWeight="Bold" Opacity="0.45" Margin="12,4,0,0" />
          <ListBox Grid.Row="1"
                 Classes="navList"
                 ItemsSource="{Binding WorkspaceNav}"
                 SelectedItem="{Binding SelectedWorkspaceNavItem, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Subtitle}" FontSize="10" FontWeight="Bold" Opacity="0.45" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" ClipToBounds="True" MinWidth="0" Classes="panel" Background="#111718">
        <Grid>
          <workspaces:RunWorkspaceView IsVisible="{Binding IsRunWorkspaceVisible}" />
          <workspaces:SpecialWorkspaceView IsVisible="{Binding IsSpecialWorkspaceVisible}" />
          <workspaces:ChoicesWorkspaceView IsVisible="{Binding IsChoicesWorkspaceVisible}" />
          <workspaces:RecognitionWorkspaceView IsVisible="{Binding IsRecognitionWorkspaceVisible}" />
          <workspaces:OutputWorkspaceView IsVisible="{Binding IsOutputWorkspaceVisible}" />
          <workspaces:RuntimeWorkspaceView IsVisible="{Binding IsRuntimeWorkspaceVisible}" />
          <workspaces:DebugWorkspaceView IsVisible="{Binding IsDebugWorkspaceVisible}" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="panel" Padding="12,7" CornerRadius="7">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsBusy}">
          <ProgressBar IsIndeterminate="True" Width="70" Height="4" VerticalAlignment="Center" />
          <TextBlock Text="処理中" FontSize="12" Opacity="0.75" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap" Opacity="0.8" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding CaptureState}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="480" Opacity="0.55" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</suki:SukiWindow>
