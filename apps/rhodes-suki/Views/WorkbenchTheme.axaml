<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="clr-namespace:RhodesSuki.Services">
  <!--
    ワークベンチ共有テーマ。
    MainWindowと分割後の各ワークスペースUserControlが同じ見た目を共有するため、
    DataTemplate・コンバーター・共通スタイルをここへ集約する。
  -->
  <Styles.Resources>
    <SolidColorBrush x:Key="WorkbenchBase">#090C0E</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchSidebar">#101518</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchToolbar">#F012171A</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchContent">#0C1114</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchFloating">#171E22</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchHover">#222C31</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchPressed">#2B383E</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchSeparator">#303A3F</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchTextPrimary">#F4F7F6</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchTextSecondary">#B3BEBA</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchTextTertiary">#85928D</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchAccent">#62C7B6</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchAccentStrong">#177E6D</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchThemeAccent">#E7B94E</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchSuccess">#50D394</SolidColorBrush>
    <SolidColorBrush x:Key="WorkbenchDanger">#FF7478</SolidColorBrush>
    <DataTemplate x:Key="PlainComboItemTemplate">
      <TextBlock Text="{Binding}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="CampaignComboItemTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="ResourceProfileComboItemTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="AdbPresetComboItemTemplate">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding PathSummary}" Foreground="#AAB6B8" FontSize="11" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="AdbPresetSelectionTemplate">
      <TextBlock Text="{Binding DisplayName}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="OcrEngineComboItemTemplate">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding Detail}" Foreground="#AAB6B8" FontSize="11" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="OcrEngineSelectionTemplate">
      <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <DataTemplate x:Key="AdbMethodComboItemTemplate">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding Detail}" Foreground="#AAB6B8" FontSize="11" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="AdbMethodSelectionTemplate">
      <TextBlock Text="{Binding Label}" Foreground="#E8EFEF" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
    </DataTemplate>
    <services:RhodesBitmapPathConverter x:Key="BitmapPathConverter" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource WorkbenchBase}" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
  </Style>
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="LetterSpacing" Value="0" />
  </Style>
  <Style Selector="Button">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="{StaticResource WorkbenchFloating}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchSeparator}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{StaticResource WorkbenchHover}" />
    <Setter Property="BorderBrush" Value="#56636A" />
  </Style>
  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{StaticResource WorkbenchPressed}" />
    <Setter Property="Opacity" Value="0.78" />
  </Style>
  <Style Selector="Button:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchAccent}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="ToggleButton">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="{StaticResource WorkbenchFloating}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchSeparator}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="ToggleButton:checked">
    <Setter Property="Background" Value="#16352F" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchAccent}" />
  </Style>

  <Style Selector="ComboBox, TextBox, NumericUpDown">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="Background" Value="{StaticResource WorkbenchFloating}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchSeparator}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="MaxDropDownHeight" Value="360" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextPrimary}" />
    <Setter Property="Background" Value="{StaticResource WorkbenchContent}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="{StaticResource WorkbenchHover}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="#34433F" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="WrapPanel.runtimeActions Button">
    <Setter Property="Margin" Value="0,0,8,8" />
  </Style>
  <!--
    選択リストはItemsControlで表示する (ListBoxは使わない)。
    行コンテナに選択/フォーカスの視覚状態が付くと、クリックのたびに行全体へ
    テーマ由来の枠が出てしまう。選択の表示はカード(Button.catalogItem)のみが担う。
    仮想化のためテンプレートでScrollViewer+VirtualizingStackPanelを与える。
  -->
  <Style Selector="ItemsControl.choicePane">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <ControlTemplate>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
        </ScrollViewer>
      </ControlTemplate>
    </Setter>
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <VirtualizingStackPanel />
      </ItemsPanelTemplate>
    </Setter>
  </Style>
  <!-- 主アクション。1画面に原則1つだけ使う。 -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource WorkbenchAccentStrong}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchAccent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="#D9FFF3" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="14,7" />
  </Style>
  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="#21917D" />
  </Style>
  <Style Selector="Button.primary:pressed">
    <Setter Property="Background" Value="#1A3E36" />
  </Style>
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="#351A1D" />
    <Setter Property="BorderBrush" Value="#714048" />
    <Setter Property="Foreground" Value="#FFB2B5" />
  </Style>
  <Style Selector="Button.tertiary">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextSecondary}" />
  </Style>
  <Style Selector="Button.primaryAction">
    <Setter Property="Background" Value="{StaticResource WorkbenchAccentStrong}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchAccent}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>
  <Style Selector="Button.primaryAction:pointerover">
    <Setter Property="Background" Value="#21917D" />
  </Style>
  <Style Selector="Button.tertiaryAction">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextSecondary}" />
  </Style>
  <Style Selector="Button.dangerAction">
    <Setter Property="Background" Value="#351A1D" />
    <Setter Property="BorderBrush" Value="#714048" />
    <Setter Property="Foreground" Value="#FFB2B5" />
  </Style>
  <Style Selector="Button.catalogItem">
    <Setter Property="MinHeight" Value="72" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="#12181B" />
  </Style>
  <Style Selector="Button.catalogItem.selected">
    <Setter Property="Background" Value="#16352F" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchAccent}" />
  </Style>
  <Style Selector="Button.catalogItem.excluded">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="RadioButton.segmented">
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Padding" Value="14,6" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="SegmentSurface" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
          <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.segmented:pointerover /template/ Border#SegmentSurface">
    <Setter Property="Background" Value="#273034" />
  </Style>
  <Style Selector="RadioButton.segmented:checked /template/ Border#SegmentSurface">
    <Setter Property="Background" Value="#34433F" />
  </Style>

  <!-- 左ナビ。選択中のワークスペースを常に可視化する。 -->
  <Style Selector="ListBox.navList">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBox.navList ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="Margin" Value="0,2" />
    <Setter Property="MinHeight" Value="54" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="ListBox.navList ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource WorkbenchHover}" />
  </Style>
  <Style Selector="ListBox.navList ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="#1B3833" />
  </Style>

  <!-- 文字階層は3段階に固定する。9-10pxは使わない。 -->
  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="25" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="31" />
  </Style>
  <Style Selector="TextBlock.displayTitle">
    <Setter Property="FontSize" Value="25" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="31" />
  </Style>
  <Style Selector="TextBlock.sectionTitle">
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="22" />
  </Style>
  <Style Selector="TextBlock.metricValue">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="29" />
  </Style>
  <Style Selector="TextBlock.body">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="LineHeight" Value="19" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextSecondary}" />
  </Style>
  <Style Selector="TextBlock.eyebrow">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextTertiary}" />
  </Style>
  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="22" />
  </Style>
  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource WorkbenchTextTertiary}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Consolas" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.72" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="#13191C" />
    <Setter Property="BorderBrush" Value="#2A353A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="14" />
  </Style>
  <Style Selector="Border.appleCard">
    <Setter Property="Background" Value="#13191C" />
    <Setter Property="BorderBrush" Value="#2A353A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="14" />
  </Style>
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{StaticResource WorkbenchContent}" />
    <Setter Property="BorderBrush" Value="{StaticResource WorkbenchSeparator}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="20" />
  </Style>
  <Style Selector="Border.appleToolbar">
    <Setter Property="Background" Value="{StaticResource WorkbenchToolbar}" />
    <Setter Property="BorderBrush" Value="#273136" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="18,10" />
  </Style>
  <Style Selector="Border.appleSidebar">
    <Setter Property="Background" Value="{StaticResource WorkbenchSidebar}" />
    <Setter Property="BorderBrush" Value="#273136" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="10" />
  </Style>
  <Style Selector="Border.appleWorkspace">
    <Setter Property="Background" Value="{StaticResource WorkbenchContent}" />
    <Setter Property="Padding" Value="22" />
  </Style>
  <Style Selector="Border.filterBar">
    <Setter Property="Background" Value="#11171A" />
    <Setter Property="BorderBrush" Value="#2A353A" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="8" />
  </Style>
  <Style Selector="Border.metricBand">
    <Setter Property="Background" Value="#101619" />
    <Setter Property="BorderBrush" Value="#293439" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="15,11" />
  </Style>
  <Style Selector="Border.statusChip">
    <Setter Property="Background" Value="#163329" />
    <Setter Property="BorderBrush" Value="#347C68" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="17" />
    <Setter Property="Padding" Value="12,6" />
  </Style>
  <Style Selector="Border.resultBanner">
    <Setter Property="Background" Value="#123027" />
    <Setter Property="BorderBrush" Value="#2F745F" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="12,9" />
  </Style>
  <Style Selector="Border.statusBar">
    <Setter Property="Background" Value="#0D1214" />
    <Setter Property="BorderBrush" Value="#273136" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="16,6" />
  </Style>

  <Style Selector="Expander">
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>
</Styles>
