<UserControl
    x:Class="RhodesSuki.Views.Workspaces.RunWorkspaceView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="18">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
        <StackPanel Spacing="4">
          <TextBlock Text="ラン" Classes="displayTitle" />
          <TextBlock Text="配信中に必要な取得値、手動補正、ボス、現在の選択を管理します。" Classes="body" />
        </StackPanel>
        <Button Grid.Column="1" Classes="dangerAction" Content="ランをクリア"
                Command="{Binding ShowClearRunConfirmationCommand}" />
      </Grid>

      <Border Classes="resultBanner" IsVisible="{Binding IsClearRunConfirmationVisible}">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
          <TextBlock Text="ラン値・特殊値・ボス・オペレーター・秘宝を初期化します。この操作は元に戻せません。"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="tertiaryAction" Content="キャンセル" Command="{Binding CancelClearRunCommand}" />
          <Button Grid.Column="2" Classes="dangerAction" Content="クリア実行" Command="{Binding ConfirmClearRunCommand}" />
        </Grid>
      </Border>

      <Border Classes="filterBar">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
          <Button Content="撮影" Command="{Binding CaptureCommand}" />
          <Button Grid.Column="1" Content="基本情報"
                  Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="runStatusFull" />
          <Button Grid.Column="2" Content="特殊値" Command="{Binding RunCurrentSpecialRecognitionAndApplyCommand}" />
          <Button Grid.Column="3" Content="オペレーター"
                  Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="operatorsFull" />
          <Button Grid.Column="4" Content="秘宝"
                  Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="relicsFull" />
          <TextBlock Grid.Column="6" Text="{Binding LastCandidateApplySummary}" Classes="caption"
                     MaxWidth="420" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border Classes="metricBand" Padding="0">
        <ItemsControl ItemsSource="{Binding HeaderStatusChips}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="18,14" BorderBrush="{StaticResource WorkbenchBorder}" BorderThickness="0,0,1,0"
                      MinHeight="92" ToolTip.Tip="{Binding Detail}">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding Label}" Classes="eyebrow" />
                  <TextBlock Text="{Binding Value}" Classes="metricValue" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Detail}" Classes="caption" MaxLines="1" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <Grid ColumnDefinitions="2*,1.15*" ColumnSpacing="16">
        <Border Classes="appleCard">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="手動補正" Classes="sectionTitle" />
                <TextBlock Text="大会進行中に変わった値だけを修正します。" Classes="caption" />
              </StackPanel>
              <Button Grid.Column="1" Classes="primaryAction" Content="反映" Command="{Binding ApplyManualRunValuesCommand}" />
            </Grid>

            <Border Grid.Row="1" Classes="resultBanner" IsVisible="{Binding IsManualDifficultyCampaign}">
              <TextBlock Text="{Binding ManualDifficultyGuidance}" TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,*,1.45*" ColumnSpacing="12">
              <StackPanel Spacing="5">
                <TextBlock Text="源石錐" Classes="eyebrow" />
                <NumericUpDown Minimum="0" Maximum="9999" Increment="1" FormatString="0"
                               Value="{Binding ManualIngot, Mode=TwoWay}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock Text="等級" Classes="eyebrow" />
                <NumericUpDown Minimum="1" Maximum="{Binding ManualDifficultyMaximum}" Increment="1" FormatString="0"
                               Value="{Binding ManualDifficulty, Mode=TwoWay}" />
                <TextBlock Text="{Binding ManualDifficultyTierLabel}" Classes="caption" Foreground="{StaticResource WorkbenchSuccess}" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="5">
                <TextBlock Text="分隊" Classes="eyebrow" />
                <ComboBox ItemsSource="{Binding ManualSquadOptions}" SelectedItem="{Binding SelectedManualSquad, Mode=TwoWay}" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="12" IsVisible="{Binding IsManualSquadRandomEffectVisible}">
              <TextBlock Text="追加効果" Classes="eyebrow" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1" ItemsSource="{Binding ManualSquadRandomEffectOptions}"
                        SelectedItem="{Binding SelectedManualSquadRandomEffect, Mode=TwoWay}" />
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Column="1" Classes="appleCard">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
            <StackPanel Spacing="2">
              <TextBlock Text="現在の選択" Classes="sectionTitle" />
              <TextBlock Text="{Binding RunSelectionSummary}" Classes="caption" />
            </StackPanel>
            <ItemsControl Grid.Row="1" ItemsSource="{Binding RunSelectionHighlights}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="56" Height="56" Margin="0,0,8,8" CornerRadius="7" ClipToBounds="True"
                          Background="{StaticResource WorkbenchSurfaceRaised}" BorderBrush="{StaticResource WorkbenchBorder}" BorderThickness="1"
                          ToolTip.Tip="{Binding Name}">
                    <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="UniformToFill" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Grid.Row="2" Classes="tertiaryAction" Content="選択を編集" HorizontalAlignment="Right"
                    Command="{Binding SetWorkspaceCommand}" CommandParameter="choices" />
          </Grid>
        </Border>
      </Grid>

      <Border Classes="appleCard">
        <StackPanel Spacing="12">
          <StackPanel Spacing="2">
            <TextBlock Text="ボス" Classes="sectionTitle" />
            <TextBlock Text="最大4体を横並びで登録できます。選択内容はOBS出力へ即時反映されます。" Classes="caption" />
          </StackPanel>
          <ItemsControl ItemsSource="{Binding BossSections}" HorizontalAlignment="Stretch">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><UniformGrid Columns="4" HorizontalAlignment="Stretch" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border MinWidth="0" Margin="0,0,10,0" Padding="10"
                        Background="{StaticResource WorkbenchSurfaceRaised}" BorderBrush="{StaticResource WorkbenchBorder}" BorderThickness="1" CornerRadius="7">
                  <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <Grid ColumnDefinitions="64,*" ColumnSpacing="10">
                      <Border Width="64" Height="64" CornerRadius="6" ClipToBounds="True"
                              Background="{StaticResource WorkbenchCanvas}" BorderBrush="{StaticResource WorkbenchBorder}" BorderThickness="1">
                        <Image Source="{Binding SelectedOption.ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="UniformToFill" />
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Helper}" Classes="caption" MaxLines="2" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Grid>
                    <ComboBox Grid.Row="1" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                              IsVisible="{Binding IsSingleSelection}" HorizontalAlignment="Stretch">
                      <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Options}" IsVisible="{Binding AllowsMultiple}">
                      <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Classes="catalogItem" Classes.selected="{Binding IsSelected}"
                                  Content="{Binding DisplayName}"
                                  Command="{Binding DataContext.ToggleBossOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" Padding="8,5" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
