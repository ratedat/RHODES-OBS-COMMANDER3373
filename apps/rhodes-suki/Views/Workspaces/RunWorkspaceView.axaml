<UserControl
    x:Class="RhodesSuki.Views.Workspaces.RunWorkspaceView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    ホーム(ラン)ダッシュボード。
    上段: 最新キャプチャ + 認識ループの主操作。
    下段: ラン値 / IS特殊値 / 認識候補 / 進行。
  -->
  <Grid RowDefinitions="Auto,*" RowSpacing="12">
    <Grid ColumnDefinitions="300,*" ColumnSpacing="12">
      <Border Classes="card" Padding="8">
        <Grid RowDefinitions="*,Auto" RowSpacing="6">
          <Border CornerRadius="6" Background="#0C1011" ClipToBounds="True" Height="150">
            <Image Source="{Binding LastCaptureImage}" Stretch="Uniform" />
          </Border>
          <TextBlock Grid.Row="1" Text="{Binding CapturePixelSizeLabel}" Classes="mono" TextTrimming="CharacterEllipsis" />
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="card">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding RunContextSummary}" Classes="h2" TextWrapping="Wrap" />
            <TextBlock Text="{Binding RunLayout.Header.Detail}" Classes="caption" />
          </StackPanel>
          <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <WrapPanel>
              <Button Content="撮影" Command="{Binding CaptureCommand}" />
              <Button Classes="primary" Content="{Binding RunCommonRecognitionLabel}" Command="{Binding RunCommonRecognitionAndApplyCommand}" />
              <Button Content="時代のみ" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="is5AgeFull" IsVisible="{Binding IsSarkazCampaignSelected}" />
              <Button Content="思案のみ" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="is5ThoughtFull" IsVisible="{Binding IsSarkazCampaignSelected}" />
              <Button Content="幻覚のみ" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="is2HallucinationsFull" IsVisible="{Binding IsPhantomCampaignSelected}" />
              <Button Content="演目のみ" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="is2PerformanceFull" IsVisible="{Binding IsPhantomCampaignSelected}" />
            </WrapPanel>
            <Button Grid.Column="1" Content="クリア" Command="{Binding ShowClearRunConfirmationCommand}" />
          </Grid>
          <Border Grid.Row="2" IsVisible="{Binding IsClearRunConfirmationVisible}" Background="#241516" BorderBrush="#A34C50" BorderThickness="1" CornerRadius="6" Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="ラン値・特殊値・ボス・オペレーター・秘宝を初期化します。この操作は元に戻せません。" TextWrapping="Wrap" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="キャンセル" Command="{Binding CancelClearRunCommand}" />
              <Button Grid.Column="2" Content="クリア実行" Command="{Binding ConfirmClearRunCommand}" />
            </Grid>
          </Border>
          <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding HeaderStatusChips}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border CornerRadius="6" Padding="9,5" Background="#121A1B" BorderBrush="#2B3638" BorderThickness="1" MinWidth="82" ToolTip.Tip="{Binding Detail}">
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding Label}" FontSize="11" Opacity="0.62" />
                      <TextBlock Text="{Binding Value}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <TextBlock Grid.Row="4" Text="{Binding LastCandidateApplySummary}" Classes="caption" />
        </Grid>
      </Border>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="14">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding RunLayout.Header.Title}" Classes="h2" />

          <!-- 共通値の手動入力: 大会配信など認識に頼らない運用向け。認識と同じ反映経路を通す。 -->
          <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
              <Border Background="#2B2110" BorderBrush="#A87B2C" BorderThickness="1" CornerRadius="5" Padding="9,6" IsVisible="{Binding IsManualDifficultyCampaign}">
                <TextBlock Text="{Binding ManualDifficultyGuidance}" Foreground="#F4CE7A" TextWrapping="Wrap" />
              </Border>
              <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="手動入力" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,6" />
                <TextBlock Text="源石錐" Classes="caption" VerticalAlignment="Center" Margin="0,0,6,6" />
                <NumericUpDown Width="130" Minimum="0" Maximum="9999" Increment="1" FormatString="0" Value="{Binding ManualIngot, Mode=TwoWay}" Margin="0,0,10,6" />
                <TextBlock Text="等級" Classes="caption" VerticalAlignment="Center" Margin="0,0,6,6" />
                <NumericUpDown Width="110" Minimum="1" Maximum="{Binding ManualDifficultyMaximum}" Increment="1" FormatString="0" Value="{Binding ManualDifficulty, Mode=TwoWay}" Margin="0,0,10,6" />
                <TextBlock Text="{Binding ManualDifficultyTierLabel}" FontSize="12" Foreground="#7BE2B6" VerticalAlignment="Center" Margin="0,0,10,6" />
                <TextBlock Text="分隊" Classes="caption" VerticalAlignment="Center" Margin="0,0,6,6" />
                <ComboBox Width="210" ItemsSource="{Binding ManualSquadOptions}" SelectedItem="{Binding SelectedManualSquad, Mode=TwoWay}" Margin="0,0,10,6" />
                <Button Content="手動反映" Command="{Binding ApplyManualRunValuesCommand}" Margin="0,0,0,6" />
              </WrapPanel>
              <WrapPanel Grid.Row="2" IsVisible="{Binding IsManualSquadRandomEffectVisible}">
                <TextBlock Text="追加効果" Classes="caption" VerticalAlignment="Center" Margin="0,0,6,6" />
                <ComboBox Width="470" ItemsSource="{Binding ManualSquadRandomEffectOptions}" SelectedItem="{Binding SelectedManualSquadRandomEffect, Mode=TwoWay}" Margin="0,0,10,6" />
              </WrapPanel>
              <TextBlock Grid.Row="3" Classes="caption" Text="認識と同じ経路でstateとAPIへ反映します。等級を反映すると多元化珍品のtier (run.difficultyTierId) も自動的に更新されます。" />
            </Grid>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <StackPanel Spacing="2">
                <TextBlock Text="ボス選択" FontSize="13" FontWeight="SemiBold" />
                <TextBlock Text="到達したステージを選択します。選択内容はラン状態とOBS表示へ保存されます。" Classes="caption" />
              </StackPanel>
              <ItemsControl ItemsSource="{Binding BossSections}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="520" MinHeight="116" Margin="0,0,10,10" Padding="10" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1" CornerRadius="6">
                      <Grid ColumnDefinitions="76,*" ColumnSpacing="10">
                        <Border Width="72" Height="72" CornerRadius="5" Background="#121A1B" BorderBrush="#344244" BorderThickness="1" VerticalAlignment="Top">
                          <Image Source="{Binding SelectedOption.ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="6">
                          <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Helper}" Classes="caption" TextWrapping="Wrap" />
                          <ComboBox ItemsSource="{Binding Options}"
                                    SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                                    IsVisible="{Binding IsSingleSelection}"
                                    HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                              <DataTemplate><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <ItemsControl ItemsSource="{Binding Options}" IsVisible="{Binding AllowsMultiple}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Button Classes="choiceCard"
                                        Classes.selected="{Binding IsSelected}"
                                        Content="{Binding DisplayName}"
                                        Command="{Binding DataContext.ToggleBossOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,5" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <ItemsControl ItemsSource="{Binding RunFieldPreviews}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="card" Width="196" MinHeight="92" Margin="0,0,10,10">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Label}" Classes="caption" />
                    <TextBlock Text="{Binding Value}" FontSize="26" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Detail}" Classes="caption" TextTrimming="CharacterEllipsis" MaxLines="2" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <StackPanel Spacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding RunCampaignSection.Title}" Classes="h2" />
            <TextBlock Text="{Binding CampaignHeaderDetail}" Classes="caption" />
          </StackPanel>
          <ItemsControl ItemsSource="{Binding CampaignPreviews}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="card" Padding="10" Margin="0,0,0,8">
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Detail}" Classes="caption" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentRunLabel}" Classes="caption" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="{Binding CurrentRunActionLabel}" Command="{Binding DataContext.SetCurrentCampaignCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" IsEnabled="{Binding CanSetCurrentRun}" Padding="8,4" VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
