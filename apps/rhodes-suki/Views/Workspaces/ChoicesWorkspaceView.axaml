<UserControl
    x:Class="RhodesSuki.Views.Workspaces.ChoicesWorkspaceView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding ChoicesLayout.Header.Title}" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ChoicesLayout.Header.Detail}" FontSize="12" Opacity="0.62" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button Content="オペレーター" Command="{Binding SetChoiceTabCommand}" CommandParameter="operators" />
        <Button Content="秘宝" Command="{Binding SetChoiceTabCommand}" CommandParameter="relics" />
        <Button Content="オペ認識" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="operatorsFull" />
        <Button Content="秘宝認識" Command="{Binding RunProfileRecognitionAndApplyCommand}" CommandParameter="relicsFull" />
        <Button Content="表示中の選択解除" Command="{Binding ClearVisibleChoicesCommand}" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" CornerRadius="7" Padding="10,8" Background="#121A1B" BorderBrush="#2B3638" BorderThickness="1">
      <TextBlock Text="{Binding ChoicePanelTitle}" FontSize="13" FontWeight="SemiBold" />
    </Border>

    <Grid Grid.Row="2">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="{Binding IsOperatorsPanelVisible}">
        <Grid ColumnDefinitions="*,150,160,180" ColumnSpacing="8">
          <TextBox Text="{Binding OperatorSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="名前、職業、職分で検索" />
          <ComboBox Grid.Column="1" ItemsSource="{Binding OperatorRarityOptions}" SelectedItem="{Binding OperatorRarityFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
          <ComboBox Grid.Column="2" ItemsSource="{Binding OperatorClassOptions}" SelectedItem="{Binding OperatorClassFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
          <ComboBox Grid.Column="3" ItemsSource="{Binding OperatorBranchOptions}" SelectedItem="{Binding OperatorBranchFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,100,Auto,Auto,Auto" ColumnSpacing="14">
          <TextBlock Text="{Binding OperatorListSummary}" FontSize="12" VerticalAlignment="Center" Opacity="0.72" />
          <TextBlock Grid.Column="1" Text="列" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
          <NumericUpDown Grid.Column="2" Minimum="1" Maximum="4" Increment="1" FormatString="0" Value="{Binding OperatorPaneColumns, Mode=TwoWay}" />
          <CheckBox Grid.Column="3" Content="優先表示" IsChecked="{Binding OperatorShowSelectedFirst, Mode=TwoWay}" />
          <CheckBox Grid.Column="4" Content="除外を隠す" IsChecked="{Binding OperatorHideExcluded, Mode=TwoWay}" />
          <CheckBox Grid.Column="5" Content="選択のみ" IsChecked="{Binding OperatorSelectedOnly, Mode=TwoWay}" />
        </Grid>

        <ItemsControl Grid.Row="2" Classes="choicePane" ItemsSource="{Binding FilteredOperatorRows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding Columns}" HorizontalAlignment="Stretch" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="choiceCard" Classes.selected="{Binding IsSelected}" Classes.excluded="{Binding IsExcluded}" Command="{Binding DataContext.ToggleChoiceSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="70">
                      <Grid ColumnDefinitions="48,*" ColumnSpacing="8">
                        <Border Width="42" Height="42" CornerRadius="6" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1" VerticalAlignment="Top">
                          <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2">
                          <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Heading}" FontSize="11" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding StateLabel}" FontSize="10" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>

      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" IsVisible="{Binding IsRelicsPanelVisible}">
        <Grid ColumnDefinitions="*,260" ColumnSpacing="8">
          <TextBox Text="{Binding RelicSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="秘宝名、番号、効果で検索" />
          <ComboBox Grid.Column="1" ItemsSource="{Binding RelicCategoryOptions}" SelectedItem="{Binding RelicCategoryFilter, Mode=TwoWay}" ItemTemplate="{StaticResource PlainComboItemTemplate}" SelectionBoxItemTemplate="{StaticResource PlainComboItemTemplate}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,100,Auto,Auto,Auto" ColumnSpacing="14">
          <TextBlock Text="{Binding RelicListSummary}" FontSize="12" VerticalAlignment="Center" Opacity="0.72" />
          <TextBlock Grid.Column="1" Text="列" FontSize="12" VerticalAlignment="Center" Opacity="0.66" />
          <NumericUpDown Grid.Column="2" Minimum="1" Maximum="4" Increment="1" FormatString="0" Value="{Binding RelicPaneColumns, Mode=TwoWay}" />
          <CheckBox Grid.Column="3" Content="優先表示" IsChecked="{Binding RelicShowSelectedFirst, Mode=TwoWay}" />
          <CheckBox Grid.Column="4" Content="除外を隠す" IsChecked="{Binding RelicHideExcluded, Mode=TwoWay}" />
          <CheckBox Grid.Column="5" Content="選択のみ" IsChecked="{Binding RelicSelectedOnly, Mode=TwoWay}" />
        </Grid>

        <ItemsControl Grid.Row="2" Classes="choicePane" ItemsSource="{Binding FilteredRelicRows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding Columns}" HorizontalAlignment="Stretch" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="choiceCard" Classes.selected="{Binding IsSelected}" Classes.excluded="{Binding IsExcluded}" Command="{Binding DataContext.ToggleChoiceSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinHeight="118">
                      <Grid RowDefinitions="Auto,*" RowSpacing="7">
                        <Grid ColumnDefinitions="48,*" ColumnSpacing="8">
                          <Border Width="42" Height="42" CornerRadius="6" Background="#0C1011" BorderBrush="#2B3638" BorderThickness="1" VerticalAlignment="Top">
                            <Image Source="{Binding ImagePath, Converter={StaticResource BitmapPathConverter}}" Stretch="Uniform" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Heading}" FontSize="11" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StateLabel}" FontSize="10" Opacity="0.72" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </Grid>
                        <TextBlock Grid.Row="1" Text="{Binding Detail}" FontSize="11" TextWrapping="Wrap" MaxLines="3" Opacity="0.58" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
